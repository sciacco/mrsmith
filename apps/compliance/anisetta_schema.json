          "definition": "CREATE OR REPLACE FUNCTION public.aggiorna_stato_richiesta_dopo_fattibilita()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$\nBEGIN\n    -- Aggiorna lo stato della richiesta da 'nuova' a 'in corso'\n    UPDATE rdf_richieste \n    SET stato = 'in corso'\n    WHERE id = NEW.richiesta_id \n    AND stato = 'nuova';\n    \n    RETURN NEW;\nEND;\n$function$\n"
