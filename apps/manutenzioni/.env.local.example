# Copy this file to `.env.local` to activate the dev auth bypass.
# `.env.local` is gitignored; its values apply only to your local dev server.
#
# Frontend — skip Keycloak and inject a fake authenticated user:
#   VITE_DEV_AUTH_BYPASS=true
#
# Optional: override the fake user. If VITE_DEV_FAKE_ROLES is unset, the
# frontend injects [app_devadmin] which auto-authorizes every hasAnyRole()
# check (client-side). Set a comma-separated list to simulate a scoped user:
#   VITE_DEV_FAKE_ROLES=app_manutenzioni_access
#   VITE_DEV_FAKE_NAME=Mario Rossi
#   VITE_DEV_FAKE_EMAIL=mario@local
#
# The backend has its own separate bypass. Start the backend with:
#   SKIP_KEYCLOAK=true make dev
# Optional backend env vars (see backend/internal/auth/middleware.go):
#   DEV_FAKE_ROLES=app_manutenzioni_access,app_manutenzioni_manager
#   DEV_FAKE_SUBJECT=dev-user-001
#   DEV_FAKE_EMAIL=mario@local
#   DEV_FAKE_NAME=Mario Rossi

VITE_DEV_AUTH_BYPASS=true
