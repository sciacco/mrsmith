{
  "name": "mrsmith",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently --names backend,apps --prefix-colors blue,green \"cd backend && air\" \"pnpm --filter './apps/*' --parallel --if-present dev\"",
    "dev:backend": "cd backend && air",
    "dev:portal": "pnpm --filter mrsmith-portal dev",
    "dev:budget": "pnpm --filter mrsmith-budget dev",
    "dev:fornitori": "pnpm --filter mrsmith-fornitori dev",
    "dev:rda": "pnpm --filter mrsmith-rda dev",
    "dev:compliance": "pnpm --filter mrsmith-compliance dev",
    "dev:kit-products": "pnpm --filter mrsmith-kit-products dev",
    "dev:listini": "pnpm --filter mrsmith-listini-e-sconti dev",
    "dev:manutenzioni": "pnpm --filter mrsmith-manutenzioni dev",
    "dev:training": "pnpm --filter mrsmith-training dev",
    "dev:panoramica": "pnpm --filter mrsmith-panoramica-cliente dev",
    "dev:quotes": "pnpm --filter mrsmith-quotes dev",
    "dev:ordini": "pnpm --filter mrsmith-ordini dev",
    "dev:richieste-fattibilita": "pnpm --filter mrsmith-richieste-fattibilita dev",
    "dev:rdf-backend": "pnpm --filter mrsmith-rdf-backend dev",
    "dev:reports": "pnpm --filter mrsmith-reports dev",
    "dev:coperture": "pnpm --filter mrsmith-coperture dev",
    "dev:energia-dc": "pnpm --filter mrsmith-energia-dc dev",
    "dev:simulatori-vendita": "pnpm --filter mrsmith-simulatori-vendita dev",
    "dev:afc-tools": "pnpm --filter @mrsmith/afc-tools dev",
    "dev:cp-backoffice": "pnpm --filter mrsmith-cp-backoffice dev",
    "build": "pnpm -r --if-present build && cd backend && go build -o bin/server ./cmd/server",
    "build:frontend": "pnpm -r --if-present build",
    "build:backend": "cd backend && go build -o bin/server ./cmd/server",
    "test": "cd backend && go test ./... && pnpm -r --if-present test",
    "lint": "cd backend && golangci-lint run && pnpm -r --if-present lint",
    "lint:css": "stylelint \"apps/quotes/src/**/*.module.css\" \"packages/ui/src/components/**/*.module.css\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "stylelint": "^16.12.0"
  }
}
