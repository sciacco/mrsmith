# Server
PORT=8080

# Skip Keycloak auth (dev only — injects a fake John Doe user)
SKIP_KEYCLOAK=false

# Keycloak — backend token validation
KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/mrsmith-dev

# Keycloak — frontend public client (served via GET /config, no secrets)
KEYCLOAK_FRONTEND_URL=https://keycloak.example.com
KEYCLOAK_FRONTEND_REALM=mrsmith-dev
KEYCLOAK_FRONTEND_CLIENT_ID=mrsmith-budget

# Keycloak — Admin API resolver (backend-only, never served via GET /config)
# Required before backend code resolves users by realm role. The service account
# should have read-only Admin API permissions for users, groups, and realm roles.
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
# Optional overrides. Defaults derive from KEYCLOAK_FRONTEND_* and KEYCLOAK_ISSUER_URL.
# KEYCLOAK_ADMIN_BASE_URL=https://keycloak.example.com
# KEYCLOAK_ADMIN_REALM=mrsmith-dev
# KEYCLOAK_ADMIN_TOKEN_URL=https://keycloak.example.com/realms/mrsmith-dev/protocol/openid-connect/token

# Arak / MISTRA-NG API proxy (service account client credentials grant)
# When set, report handlers proxy to real API instead of using fixtures.
# ARAK_BASE_URL=https://gw-int.cdlan.net
# ARAK_SERVICE_CLIENT_ID=mrsmith-bff
# ARAK_SERVICE_CLIENT_SECRET=change-me
# ARAK_SERVICE_TOKEN_URL=https://keycloak.example.com/realms/mrsmith-dev/protocol/openid-connect/token

# Arak PostgreSQL used by Fornitori and RDA catalogs.
ARAK_DSN=

# SMTP email delivery (disabled unless SMTP_ENABLED=true)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
# TLS modes: auto, starttls, implicit, none
SMTP_TLS_MODE=auto
# Set true only for internal/self-signed SMTP endpoints.
SMTP_TLS_SKIP_VERIFY=false
# Optional certificate/SNI server name override when SMTP_HOST is an IP or alias.
SMTP_TLS_SERVER_NAME=
# Auth modes: auto, plain, login
SMTP_AUTH_MODE=auto

# Notifications
# Required for absolute links in notification emails. Portal inbox still works when empty.
MRSMITH_PUBLIC_BASE_URL=http://localhost:5173
# Worker starts by default; set false to disable email delivery processing.
NOTIFICATIONS_WORKER_ENABLED=true
NOTIFICATIONS_WORKER_INTERVAL=60s
# Keep false outside local development. Set true to let self-mentions create notifications.
NOTIFY_SELF_MENTIONS=false

# MrSmith-owned platform PostgreSQL schema used by support, notifications, and diagnostics.
ANISETTA_DSN=

# Diagnostics
# Stores backend warn/error events in Anisetta for support debugging when enabled.
# Defaults to true when ANISETTA_DSN is configured.
DIAGNOSTIC_EVENTS_ENABLED=true
DIAGNOSTIC_EVENTS_RETENTION_DAYS=90
DIAGNOSTIC_EVENTS_QUEUE_SIZE=1000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:5178,http://localhost:5179,http://localhost:5180,http://localhost:5181,http://localhost:5182,http://localhost:5183,http://localhost:5184,http://localhost:5185,http://localhost:5186,http://localhost:5187,http://localhost:5188,http://localhost:5189,http://localhost:5190

# Static files directory (leave empty in dev, set in production)
STATIC_DIR=

# Show catalog entries marked Status: "dev" in the portal launcher.
# Default false — production hides them automatically. Set to true in dev.
INCLUDE_DEV_APPS=true

# Database connections (per app, add as needed)
# HR_DB_DRIVER=postgres
# HR_DB_DSN=postgres://user:pass@host:5432/hrdb?sslmode=require
# FINANCE_DB_DRIVER=mssql
# FINANCE_DB_DSN=sqlserver://user:pass@host:1433?database=financedb

# Coperture PostgreSQL used by the Coperture mini-app. Requires the operator seed
# migration in deploy/migrations/003_coperture_network_coverage_operators.sql.
DBCOPERTURE_DSN=

# Shared Grappa MySQL used by Energia in DC.
# Format: user:password@tcp(host:3306)/grappa?parseTime=true&charset=latin1
GRAPPA_DSN=

# Manutenzioni PostgreSQL. Apply docs/manutenzioni_schema.sql before use.
MANUTENZIONI_DSN=

# Optional split-server frontend override for Manutenzioni local development.
MANUTENZIONI_APP_URL=

# Optional split-server frontend override for RDA local development.
RDA_APP_URL=

# RDA quote threshold for requiring at least 2 quote attachments before submit.
RDA_QUOTE_THRESHOLD=3000

# Optional split-server frontend override for Energia in DC local development.
ENERGIA_DC_APP_URL=

# Optional split-server frontend override for Simulatori di Vendita local development.
SIMULATORI_VENDITA_APP_URL=

# Customer IDs excluded only from the "Senza variabile" customer list.
ENERGIA_DC_EXCLUDED_CUSTOMER_IDS=3

# Optional Carbone Cloud API for simulatori exports.
CARBONE_API_KEY=

# Optional Carbone template override for Simulatori di Vendita.
# When empty, the backend uses the audited Appsmith template id by default.
SIMULATORI_VENDITA_IAAS_TEMPLATE_ID=

# AFC Tools mini-app — MySQL to Vodka/daiquiri (Sales/CRM orders DB) and WHMCS (Prometeus).
# Format: user:password@tcp(host:3306)/dbname?parseTime=true
VODKA_DSN=
WHMCS_DSN=

# Optional split-server frontend override for AFC Tools local development.
AFCTOOLS_APP_URL=

# Optional Carbone template override for AFC Tools Transazioni WHMCS XLSX export.
# When empty, the backend uses the template id extracted from the Appsmith app.
CARBONE_AFCTOOLS_TRANSAZIONI_TEMPLATE_ID=

# Optional split-server frontend override for CP Backoffice local development.
CP_BACKOFFICE_APP_URL=
