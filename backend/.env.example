# Server
PORT=8080

# Skip Keycloak auth (dev only — injects a fake John Doe user)
SKIP_KEYCLOAK=false

# Keycloak — backend token validation
KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/mrsmith-dev

# Keycloak — frontend public client (served via GET /config, no secrets)
KEYCLOAK_FRONTEND_URL=https://keycloak.example.com
KEYCLOAK_FRONTEND_REALM=mrsmith-dev
KEYCLOAK_FRONTEND_CLIENT_ID=mrsmith-budget

# Arak / MISTRA-NG API proxy (service account client credentials grant)
# When set, report handlers proxy to real API instead of using fixtures.
# ARAK_BASE_URL=https://gw-int.cdlan.net
# ARAK_SERVICE_CLIENT_ID=mrsmith-bff
# ARAK_SERVICE_CLIENT_SECRET=change-me
# ARAK_SERVICE_TOKEN_URL=https://keycloak.example.com/realms/mrsmith-dev/protocol/openid-connect/token

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:5178,http://localhost:5179,http://localhost:5180,http://localhost:5181,http://localhost:5182,http://localhost:5183,http://localhost:5184,http://localhost:5185,http://localhost:5186

# Static files directory (leave empty in dev, set in production)
STATIC_DIR=

# Database connections (per app, add as needed)
# HR_DB_DRIVER=postgres
# HR_DB_DSN=postgres://user:pass@host:5432/hrdb?sslmode=require
# FINANCE_DB_DRIVER=mssql
# FINANCE_DB_DSN=sqlserver://user:pass@host:1433?database=financedb

# Coperture PostgreSQL used by the Coperture mini-app. Requires the operator seed
# migration in deploy/migrations/003_coperture_network_coverage_operators.sql.
DBCOPERTURE_DSN=

# Shared Grappa MySQL used by Energia in DC.
# Format: user:password@tcp(host:3306)/grappa?parseTime=true&charset=latin1
GRAPPA_DSN=

# Optional split-server frontend override for Energia in DC local development.
ENERGIA_DC_APP_URL=

# Optional split-server frontend override for Simulatori di Vendita local development.
SIMULATORI_VENDITA_APP_URL=

# Customer IDs excluded only from the "Senza variabile" customer list.
ENERGIA_DC_EXCLUDED_CUSTOMER_IDS=3

# Optional Carbone Cloud API for simulatori exports.
CARBONE_API_KEY=

# Optional Carbone template override for Simulatori di Vendita.
# When empty, the backend uses the audited Appsmith template id by default.
SIMULATORI_VENDITA_IAAS_TEMPLATE_ID=

# AFC Tools mini-app — MySQL to Vodka/daiquiri (Sales/CRM orders DB) and WHMCS (Prometeus).
# Format: user:password@tcp(host:3306)/dbname?parseTime=true
VODKA_DSN=
WHMCS_DSN=

# Optional split-server frontend override for AFC Tools local development.
AFCTOOLS_APP_URL=

# Optional Carbone template override for AFC Tools Transazioni WHMCS XLSX export.
# When empty, the backend uses the template id extracted from the Appsmith app.
CARBONE_AFCTOOLS_TRANSAZIONI_TEMPLATE_ID=
