# Imported image tag to retag locally before `docker compose up`.
# Example:
#   docker tag mrsmith:preprod-2026-04-06 mrsmith:preprod

PORT=8080
STATIC_DIR=/static

# Keycloak validation/bootstrap
KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/mrsmith
KEYCLOAK_FRONTEND_URL=https://keycloak.example.com
KEYCLOAK_FRONTEND_REALM=mrsmith
KEYCLOAK_FRONTEND_CLIENT_ID=mrsmith-portal

# Single-origin deployment: both portal and budget are served by the same backend.
CORS_ORIGINS=https://mrsmith.example.com

# Optional live Arak proxy for kit discount/simulator views.
# Leave empty to disable those proxy-backed screens.
ARAK_BASE_URL=
ARAK_SERVICE_CLIENT_ID=
ARAK_SERVICE_CLIENT_SECRET=
ARAK_SERVICE_TOKEN_URL=

# Arak PostgreSQL used by Fornitori and RDA catalogs.
ARAK_DSN=

# SMTP email delivery (disabled unless SMTP_ENABLED=true)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
# TLS modes: auto, starttls, implicit, none
SMTP_TLS_MODE=auto
# Set true only for internal/self-signed SMTP endpoints.
SMTP_TLS_SKIP_VERIFY=false
# Optional certificate/SNI server name override when SMTP_HOST is an IP or alias.
SMTP_TLS_SERVER_NAME=
# Auth modes: auto, plain, login
SMTP_AUTH_MODE=auto

# Notifications
# Required for absolute links in notification emails. Portal inbox still works when empty.
MRSMITH_PUBLIC_BASE_URL=https://mrsmith.example.com
# Worker starts by default; set false to disable email delivery processing.
NOTIFICATIONS_WORKER_ENABLED=true
NOTIFICATIONS_WORKER_INTERVAL=60s
# Keep false outside local development. Set true to let self-mentions create notifications.
NOTIFY_SELF_MENTIONS=false

# MrSmith-owned platform PostgreSQL schema used by support, notifications, and diagnostics.
ANISETTA_DSN=

# Diagnostics
# Stores backend warn/error events in Anisetta for support debugging when enabled.
# Defaults to true when ANISETTA_DSN is configured.
DIAGNOSTIC_EVENTS_ENABLED=true
DIAGNOSTIC_EVENTS_RETENTION_DAYS=90
DIAGNOSTIC_EVENTS_QUEUE_SIZE=1000

# Shared Mistra PostgreSQL used by kit-products and listini-e-sconti. Required for both apps.
MISTRA_DSN=

# Coperture PostgreSQL used by the Coperture mini-app. Apply
# deploy/migrations/003_coperture_network_coverage_operators.sql before use.
DBCOPERTURE_DSN=

# Optional Alyante ERP MSSQL used for product short-description sync.
ALYANTE_DSN=

# Grappa MySQL used by listini-e-sconti. Required for IaaS pricing, credits, racks.
# All Grappa tables use latin1 charset — use charset=latin1 (NOT utf8mb4).
# Format: user:password@tcp(host:3306)/grappa?parseTime=true&charset=latin1
GRAPPA_DSN=

# Manutenzioni PostgreSQL. Apply docs/manutenzioni_schema.sql before use.
MANUTENZIONI_DSN=

# Optional split-server frontend override for Manutenzioni.
MANUTENZIONI_APP_URL=

# Training mini-app. Requires ANISETTA_DSN plus deploy/migrations/012_anisetta_training.sql.
TRAINING_APP_URL=
TRAINING_STORAGE_DIR=
TRAINING_STORAGE_MAX_BYTES=20971520
TRAINING_JOBS_ENABLED=false
TRAINING_JOBS_INTERVAL=6h

# Optional split-server frontend override for RDA.
RDA_APP_URL=

# RDA quote threshold for requiring at least 2 quote attachments before submit.
RDA_QUOTE_THRESHOLD=3000

# Optional split-server frontend override for Energia in DC.
ENERGIA_DC_APP_URL=

# Optional split-server frontend override for Simulatori di Vendita.
SIMULATORI_VENDITA_APP_URL=

# Customer IDs excluded only from the Energia in DC "Senza variabile" list.
ENERGIA_DC_EXCLUDED_CUSTOMER_IDS=3

# Optional HubSpot integration for listini-e-sconti audit notes/tasks.
HUBSPOT_API_KEY=

# Optional Carbone Cloud API for kit PDF generation and simulatori exports.
CARBONE_API_KEY=

# Optional Carbone template override for Simulatori di Vendita.
# When empty, the backend uses the audited Appsmith template id by default.
SIMULATORI_VENDITA_IAAS_TEMPLATE_ID=

# AFC Tools — Vodka/daiquiri (Sales CRM orders) and WHMCS (Prometeus billing) MySQL.
VODKA_DSN=
WHMCS_DSN=

# Optional split-server frontend override for AFC Tools.
AFCTOOLS_APP_URL=

# Optional split-server frontend override for Ordini.
ORDINI_APP_URL=

# Optional Carbone template override for AFC Tools Transazioni WHMCS XLSX export.
# When empty, the backend uses the audited Appsmith template id by default.
CARBONE_AFCTOOLS_TRANSAZIONI_TEMPLATE_ID=

# Optional split-server frontend override for CP Backoffice.
CP_BACKOFFICE_APP_URL=
