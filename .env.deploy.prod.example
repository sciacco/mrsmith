# Copiare in .env.deploy.prod e valorizzare prima di eseguire make deploy-prod.

DEPLOY_HOST=prod.example.internal
DEPLOY_USER=root
DEPLOY_PORT=22

# Path remoto dove copiare i tar esportati.
DEPLOY_REMOTE_DIR=/root

# Compose e service in esecuzione sul server.
DEPLOY_COMPOSE_FILE=/DATI/mrsmith/docker-compose.yaml
DEPLOY_SERVICE=mrsmith

# Quanti tar mantenere sul server dopo ogni deploy riuscito.
DEPLOY_RETENTION=5

# Opzionali.
# IMAGE_NAME=mrsmith:prod
# IMAGE_ARCHIVE_TAG=mrsmith:amd64
# ARTIFACT_DIR=/Users/<user>/devel/mrsmith/artifacts/releases
