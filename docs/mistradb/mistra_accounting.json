      "functions": [
        {
          "name": "acct_log_new",
          "definition": "CREATE OR REPLACE FUNCTION accounting.acct_log_new(json_data json)\n RETURNS bigint\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    _log_id bigint;\nBEGIN\n\n    INSERT INTO acct_log (api_path,\n    api_method,\n    params,\n    query,\n    request_body,\n    time,\n    duration_ms,\n    response_code,\n                          response_body,\n                          user_struct_id, source_ip, trace_id)\n    VALUES (\n    \t\tjson_data ->> 'api_path',\n            json_data ->> 'api_method',\n            (json_data ->> 'params')::JSON,\n            (json_data ->> 'query')::JSON,\n            (json_data ->> 'request_body')::JSON,\n            (json_data ->> 'time')::TIMESTAMP,\n            NULLIF((json_data ->> 'duration_ms')::BIGINT, 0),\n            (json_data ->> 'response_code')::INT,\n            (json_data ->> 'response_body')::JSON,\n            (json_data ->> 'user_struct_id')::BIGINT,\n            (json_data ->> 'source_ip')::CIDR,\n            json_data ->> 'trace_id'\n\n            )\n            RETURNING id INTO _log_id;\n\nRETURN _log_id;\n\nEND;\n$function$\n"
        }
