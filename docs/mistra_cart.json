      "functions": [
        {
          "name": "generate_bundle_code",
          "definition": "CREATE OR REPLACE FUNCTION cart.generate_bundle_code(bundle_prefix text, order_item_id bigint)\n RETURNS text\n LANGUAGE plpgsql\nAS $function$\n                BEGIN\n                    -- Generate the code in the format \"bundle_prefix - A - order_item_id\"\n                    RETURN bundle_prefix || '-A-' || order_item_id::TEXT;\n                END;\n                $function$\n"
        },
        {
          "name": "notify_order_state_change",
          "definition": "CREATE OR REPLACE FUNCTION cart.notify_order_state_change()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$\n            BEGIN\n                -- Check if the new state_id corresponds to 'activated' state\n                IF NEW.state_id = (SELECT id FROM cart.order_states WHERE name = 'in-delivery') THEN\n                    -- Notify the 'order_state_channel' with the actual order_number and state\n                    PERFORM pg_notify('order_state_channel', format('{\"order_number\": \"%s\", \"state\": \"%s\"}', NEW.order_number, 'in-delivery'));\n                END IF;\n                RETURN NEW;\n            END;\n            $function$\n"
        },
        {
          "name": "set_order_item_number",
          "definition": "CREATE OR REPLACE FUNCTION cart.set_order_item_number()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$\n                BEGIN\n                    -- Set the order_item_number by calling the generate_bundle_code function\n                    NEW.order_item_number := cart.generate_bundle_code(NEW.bundle_prefix, NEW.id);\n                    RETURN NEW;\n                END;\n                $function$\n"
        },
        {
          "name": "update_order_state",
          "definition": "CREATE OR REPLACE FUNCTION cart.update_order_state()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$            BEGIN\n                -- Declare variables to store the count of different order item states\n                DECLARE\n                    completed_count INT;\n                    cancelled_count INT;\n                    in_delivery_count INT;\n                    completed_state_id INT;\n                    cancelled_state_id INT;\n                    in_delivery_state_id INT;\n                    total_count INT;\n                BEGIN\n                    -- Get the total number of order_items for the order\n                    SELECT COUNT(*) INTO total_count\n                    FROM cart.order_items\n                    WHERE order_id = NEW.order_id;\n        \n                    -- Get the count of completed order_items for the order\n                    SELECT COUNT(*) INTO completed_count\n                    FROM cart.order_items oi\n                    JOIN cart.order_states os ON os.id = oi.state_id\n                    WHERE oi.order_id = NEW.order_id AND os.name = 'activated';\n        \n                    -- Get the count of cancelled order_items for the order\n                    SELECT COUNT(*) INTO cancelled_count\n                    FROM cart.order_items oi\n                    JOIN cart.order_states os ON os.id = oi.state_id\n                    WHERE oi.order_id = NEW.order_id AND os.name = 'cancelled';\n        \n                    -- Get the count of in-delivery order_items for the order\n                    SELECT COUNT(*) INTO in_delivery_count\n                    FROM cart.order_items oi\n                    JOIN cart.order_states os ON os.id = oi.state_id\n                    WHERE oi.order_id = NEW.order_id AND os.name = 'in-delivery';\n        \n                    -- Get the state_id for 'activated', 'cancelled', and 'in-delivery' from the order_states table\n                    SELECT id INTO completed_state_id\n                    FROM cart.order_states\n                    WHERE name = 'activated'\n                    LIMIT 1;\n        \n                    SELECT id INTO cancelled_state_id\n                    FROM cart.order_states\n                    WHERE name = 'cancelled'\n                    LIMIT 1;\n        \n                    SELECT id INTO in_delivery_state_id\n                    FROM cart.order_states\n                    WHERE name = 'in-delivery'\n                    LIMIT 1;\n        \n                    -- Check the conditions and update the orders state_id accordingly\n                    IF total_count = cancelled_count THEN\n                        -- All items are cancelled, so set the order to cancelled state\n                        UPDATE cart.orders\n                        SET state_id = cancelled_state_id\n                        WHERE id = NEW.order_id;\n\n                    ELSIF (completed_count + cancelled_count) = total_count THEN\n                        -- All items are either activated or cancelled, set the order to activated state\n                        UPDATE cart.orders\n                        SET state_id = completed_state_id\n                        WHERE id = NEW.order_id;\n\n                    ELSIF (in_delivery_count + cancelled_count) = total_count THEN\n                        -- All items are either in delivery or cancelled, set the order to in-delivery state\n                        UPDATE cart.orders\n                        SET state_id = in_delivery_state_id\n                        WHERE id = NEW.order_id;\n                    END IF;\n                \n                    RETURN NEW;\n                END;\n            END;$function$\n"
        }
