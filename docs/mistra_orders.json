      "functions": [
        {
          "name": "get_default_order_row_state",
          "definition": "CREATE OR REPLACE FUNCTION orders.get_default_order_row_state()\n RETURNS bigint\n LANGUAGE sql\nAS $function$\nSELECT id FROM order_row_state WHERE name = 'INVIATO';\n$function$\n"
        },
        {
          "name": "get_default_order_state",
          "definition": "CREATE OR REPLACE FUNCTION orders.get_default_order_state()\n RETURNS bigint\n LANGUAGE sql\nAS $function$\nSELECT id FROM order_state WHERE name = 'INVIATO';\n$function$\n"
        },
        {
          "name": "set_bundle_prefix_unique",
          "definition": "CREATE OR REPLACE FUNCTION orders.set_bundle_prefix_unique()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$\nBEGIN\n    NEW.bundle_prefix_unique = concat(NEW.bundle_prefix,'-',NEW.id::TEXT);\n    RETURN NEW;\nEND;\n$function$\n"
        },
        {
          "name": "update_order_row_state",
          "definition": "CREATE OR REPLACE FUNCTION orders.update_order_row_state()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$\nBEGIN\n\n    IF (NEW.state_id = (SELECT id FROM orders.order_state WHERE name = 'IN ATTIVAZIONE'))\n    THEN\n        UPDATE orders.order_row SET state_id = (SELECT id FROM orders.order_row_state WHERE name = 'IN ATTIVAZIONE') WHERE order_id = NEW.id AND asset_flow IS NULL;\n    end if;\n\n    IF (NEW.state_id = (SELECT id FROM orders.order_state WHERE name = 'EVASO'))\n    THEN\n        UPDATE orders.order_row SET state_id = (SELECT id FROM orders.order_row_state WHERE name = 'EVASO') WHERE order_id = NEW.id AND asset_flow IS NULL;\n    end if;\n\n    IF (NEW.state_id = (SELECT id FROM orders.order_state WHERE name = 'ANNULLATO'))\n    THEN\n        UPDATE orders.order_row SET state_id = (SELECT id FROM orders.order_row_state WHERE name = 'ANNULLATO') WHERE order_id = NEW.id;\n    end if;\n\n    RETURN NEW;\n\nend;\n$function$\n"
        },
        {
          "name": "update_order_state",
          "definition": "CREATE OR REPLACE FUNCTION orders.update_order_state()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    prev_search_path TEXT;\nBEGIN\n\n    IF EXISTS (SELECT * FROM new_table n INNER JOIN old_table o ON o.serial_number = n.serial_number WHERE n.state_id <> o.state_id AND n.asset_flow IS NOT NULL)\n    THEN\n\n        -- Store the current search_path\n        SELECT current_setting('search_path') INTO prev_search_path;\n\n        -- Set the new search_path to 'orders'\n        EXECUTE 'SET search_path TO orders';\n\n        -- IN ATTIVAZIONE\n        UPDATE \"order\" SET state_id = (SELECT id from order_state WHERE name = 'IN ATTIVAZIONE') WHERE id IN\n            (\n            SELECT order_id FROM (\n            SELECT\n            order_id,\n            count(serial_number)                          as mapped_rows,\n            SUM(CASE WHEN state_id = (SELECT id from order_row_state WHERE name = 'IN ATTIVAZIONE') THEN 1 ELSE 0 END) AS ready_rows\n            FROM order_row\n            WHERE asset_flow IS NOT NULL\n            GROUP BY order_id\n            )x WHERE mapped_rows = ready_rows\n            );\n\n        -- EVASO\n        UPDATE \"order\" SET state_id = (SELECT id from order_state WHERE name = 'EVASO') WHERE id IN\n            (\n            SELECT order_id FROM (\n            SELECT\n            order_id,\n            count(serial_number)    as mapped_rows,\n            SUM(CASE WHEN state_id = (SELECT id from order_row_state WHERE name = 'EVASO') THEN 1 ELSE 0 END) AS ready_rows\n            FROM order_row\n            WHERE asset_flow IS NOT NULL\n            GROUP BY order_id\n            )x WHERE mapped_rows = ready_rows\n            );\n\n        -- ANNULLATO\n        UPDATE \"order\" SET state_id = (SELECT id from order_state WHERE name = 'ANNULLATO') WHERE id IN\n            (\n            SELECT DISTINCT order_id FROM order_row WHERE state_id = (SELECT id FROM order_row_state WHERE name = 'ANNULLATO')\n            );\n\n        -- Restore the previous search_path\n        EXECUTE 'SET search_path TO ' || prev_search_path;\n\n    END IF;\n\n    RETURN NULL;  -- Statement-level triggers return NULL\nEND;\n$function$\n"
        }
      ],
