{
  "permissions": {
    "allow": [
      "WebFetch(domain:registry.npmjs.org)",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_take_screenshot",
      "mcp__plugin_playwright_playwright__browser_resize",
      "WebFetch(domain:proxy.golang.org)",
      "Bash(pnpm:*)",
      "Bash(GONOSUMCHECK=github.com/go-sql-driver/mysql GOFLAGS=-insecure go get github.com/go-sql-driver/mysql)",
      "Bash(GOINSECURE=github.com/go-sql-driver/mysql go get github.com/go-sql-driver/mysql)",
      "Bash(GOINSECURE=github.com/go-sql-driver/mysql go mod:*)",
      "mcp__plugin_playwright_playwright__browser_console_messages",
      "mcp__plugin_playwright_playwright__browser_close",
      "Skill(playwright-cli)",
      "Bash(playwright-cli -s=manutsmoke press PageDown)",
      "Bash(playwright-cli -s=manutsmoke screenshot --filename=/tmp/claude/manut-section.png)"
    ]
  },
  "spinnerTipsEnabled": false
}
