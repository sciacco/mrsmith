          "widget_type": "FORM_WIDGET",
          "role": "editor"
        },
        {
          "name": "SubmitOrderButton",
          "widget_type": "BUTTON_WIDGET",
          "role": "trigger"
        }
      ]
    }
  ],
  "datasources": [
    {
      "name": "Orders API",
      "datasource_type": "REST_API",
      "purpose": "System of record for order and customer data."
    }
  ],
  "actions": [
    {
      "name": "fetchOrders",
      "action_type": "api",
      "purpose": "Load a paginated order list for the landing page.",
      "entity": "Order",
      "operation": "read",
      "parameters": [
        "this.params.status",
        "this.params.page"
      ]
    },
    {
      "name": "fetchOrderDetail",
      "action_type": "api",
      "purpose": "Load one order with customer and line item data.",
      "entity": "Order",
      "operation": "read",
      "parameters": [
        "appsmith.store.selectedOrderId"
      ]
    },
    {
      "name": "saveOrder",
      "action_type": "api",
      "purpose": "Persist edits made in the detail form.",
      "entity": "Order",
      "operation": "update",
      "parameters": [
        "OrderForm.formData"
      ]
    },
    {
      "name": "submitOrder",
      "action_type": "api",
      "purpose": "Submit the order for downstream fulfillment.",
      "entity": "Order",
      "operation": "submit",
      "parameters": [
        "appsmith.store.selectedOrderId"
      ]
    }
  ],
  "entities": [
    {
      "name": "Order",
      "role": "primary",
      "fields": [
        "id",
        "orderNumber",
        "status",
        "customerId",
        "submittedAt",
        "totalAmount"
      ],
      "operations": [
        "read",
        "update",
        "submit"
      ],
      "relationships": [
