        "name",
        "email"
      ],
      "operations": [
        "read"
      ],
      "relationships": [
        "has many Order"
      ]
    },
    {
      "name": "Line Item",
      "role": "supporting",
      "fields": [
        "sku",
        "description",
        "quantity",
        "unitPrice"
      ],
      "operations": [
        "read",
        "update"
      ],
      "relationships": [
        "belongs to Order"
      ]
    }
  ],
  "js_objects": [
